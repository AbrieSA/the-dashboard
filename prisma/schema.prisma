generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SourceSystem {
  SALESFORCE
  GA4
  WEBSITE_PERFORMANCE
  GOOGLE_SHEETS
  MANUAL
}

enum SourceRunStatus {
  PENDING
  SUCCEEDED
  FAILED
  DUPLICATE
}

enum TargetType {
  CURRENT
  STANDARD
  DESIRED
}

enum Timegrain {
  WEEK
  MONTH
  YEAR
}

enum WebsitePerformanceStrategy {
  MOBILE
  DESKTOP
}

enum WebsiteDataScope {
  PAGE
  ORIGIN
}

enum HealthCategory {
  GOOD
  NEEDS_IMPROVEMENT
  POOR
}

model DashboardGroup {
  id          String             @id @default(cuid())
  key         String             @unique
  label       String
  description String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  metrics     MetricDefinition[]
}

model MetricDefinition {
  id               String              @id @default(cuid())
  key              String              @unique
  label            String
  sourceSystem     SourceSystem
  unit             String
  category         String
  subcategory      String?
  segment          String?
  directionality   String              @default("HIGHER_IS_BETTER")
  sortOrder        Int                 @default(0)
  isActive         Boolean             @default(true)
  dashboardGroup   DashboardGroup      @relation(fields: [dashboardGroupId], references: [id])
  dashboardGroupId String
  observations     MetricObservation[]
  targets          MetricTarget[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model MetricObservation {
  id                 String           @id @default(cuid())
  metricDefinition   MetricDefinition @relation(fields: [metricDefinitionId], references: [id])
  metricDefinitionId String
  observedValue      Decimal          @db.Decimal(18, 6)
  observedAt         DateTime
  timegrain          Timegrain        @default(MONTH)
  sourceSystem       SourceSystem
  segmentKey         String?
  segmentValue       String?
  notes              String?
  metadataJson       Json?
  sourceRun          SourceRun?       @relation(fields: [sourceRunId], references: [id])
  sourceRunId        String?
  createdAt          DateTime         @default(now())

  @@index([metricDefinitionId, observedAt(sort: Desc)])
  @@index([metricDefinitionId, timegrain, observedAt(sort: Desc)])
  @@index([sourceSystem, observedAt(sort: Desc)])
}

model MetricTarget {
  id                 String           @id @default(cuid())
  metricDefinition   MetricDefinition @relation(fields: [metricDefinitionId], references: [id])
  metricDefinitionId String
  targetType         TargetType
  targetValue        Decimal          @db.Decimal(18, 6)
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  sourceSystem       SourceSystem     @default(GOOGLE_SHEETS)
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([metricDefinitionId, targetType, effectiveFrom(sort: Desc)])
}

model SourceRun {
  id               String            @id @default(cuid())
  sourceSystem     SourceSystem
  externalRunId    String
  status           SourceRunStatus
  receivedAt       DateTime          @default(now())
  completedAt      DateTime?
  observationCount Int               @default(0)
  payloadJson      Json?
  errorMessage     String?
  observations     MetricObservation[]
  websiteHealthSnapshots WebsiteHealthSnapshot[]

  @@unique([sourceSystem, externalRunId])
  @@index([status, receivedAt(sort: Desc)])
}

model WebsitePage {
  id        String                  @id @default(cuid())
  key       String                  @unique
  label     String
  url       String                  @unique
  isActive  Boolean                 @default(true)
  sortOrder Int                     @default(0)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  snapshots WebsiteHealthSnapshot[]
}

model WebsiteHealthSnapshot {
  id            String                     @id @default(cuid())
  websitePage   WebsitePage                @relation(fields: [websitePageId], references: [id])
  websitePageId String
  strategy      WebsitePerformanceStrategy
  timegrain     Timegrain
  periodStart   DateTime
  fetchedAt     DateTime
  pageDataScope WebsiteDataScope
  lcpMs         Decimal?                   @db.Decimal(18, 6)
  inpMs         Decimal?                   @db.Decimal(18, 6)
  cls           Decimal?                   @db.Decimal(18, 6)
  lcpCategory   HealthCategory?
  inpCategory   HealthCategory?
  clsCategory   HealthCategory?
  requestedUrl  String
  finalUrl      String
  rawJson       Json
  sourceRun     SourceRun?                 @relation(fields: [sourceRunId], references: [id])
  sourceRunId   String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@unique([websitePageId, strategy, timegrain, periodStart])
  @@index([timegrain, periodStart(sort: Desc)])
  @@index([websitePageId, periodStart(sort: Desc)])
  @@index([sourceRunId])
}
